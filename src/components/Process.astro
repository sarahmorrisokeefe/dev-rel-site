---
---

<section id="process" style="border-top:1px solid rgba(255,255,255,0.07); background:#0c0c0e;">
  <div style="max-width:1120px; margin:0 auto; padding:104px 32px;" class="section-pad">
    <div
      data-reveal
      style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.14em; text-transform:uppercase; color:#6f6f6f; margin-bottom:10px;"
    >
      The Launch Engagement
    </div>
    <h2
      data-reveal
      style="font-weight:600; font-size:38px; line-height:1.12; letter-spacing:-0.025em; margin:0 0 56px; max-width:720px; color:#fafafa;"
    >
      From zero to a working developer relations practice in as little as eight weeks.
    </h2>

    <div class="three-col" style="display:grid; grid-template-columns:repeat(3,1fr); gap:36px;">
      <!-- Phase 1 -->
      <div data-reveal>
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:22px;">
          <span
            style="width:12px; height:12px; border-radius:50%; background:var(--accent); box-shadow:0 0 0 4px color-mix(in srgb, var(--accent) 20%, transparent); flex:none;"
          ></span>
          <span style="flex:1; height:1px; background:rgba(255,255,255,0.12);"></span>
        </div>
        <div style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.06em; color:var(--accent); margin-bottom:10px;">
          Phase 01
        </div>
        <h3 style="font-weight:600; font-size:21px; letter-spacing:-0.01em; margin:0 0 14px; color:#fafafa;">
          Discovery
        </h3>
        <div style="display:flex; flex-direction:column; gap:9px;">
          <div style="font-size:14.5px; line-height:1.55; color:#9a9a9a;">Talk to your actual users and developers</div>
          <div style="font-size:14.5px; line-height:1.55; color:#9a9a9a;">Review support tickets &amp; community channels</div>
          <div style="font-size:14.5px; line-height:1.55; color:#9a9a9a;">Audit existing docs and product surface area</div>
        </div>
      </div>

      <!-- Phase 2 -->
      <div data-reveal>
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:22px;">
          <span
            style="width:12px; height:12px; border-radius:50%; background:var(--accent); box-shadow:0 0 0 4px color-mix(in srgb, var(--accent) 20%, transparent); flex:none;"
          ></span>
          <span style="flex:1; height:1px; background:rgba(255,255,255,0.12);"></span>
        </div>
        <div style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.06em; color:var(--accent); margin-bottom:10px;">
          Phase 02
        </div>
        <h3 style="font-weight:600; font-size:21px; letter-spacing:-0.01em; margin:0 0 14px; color:#fafafa;">
          Plan
        </h3>
        <div style="display:flex; flex-direction:column; gap:9px;">
          <div style="font-size:14.5px; line-height:1.55; color:#9a9a9a;">Build a content calendar around real gaps</div>
          <div style="font-size:14.5px; line-height:1.55; color:#9a9a9a;">Identify the critical docs to fix first</div>
          <div style="font-size:14.5px; line-height:1.55; color:#9a9a9a;">Decide where the community should live</div>
        </div>
      </div>

      <!-- Phase 3 -->
      <div data-reveal>
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:22px;">
          <span
            style="width:12px; height:12px; border-radius:50%; background:var(--accent); box-shadow:0 0 0 4px color-mix(in srgb, var(--accent) 20%, transparent); flex:none;"
          ></span>
          <span style="flex:1; height:1px; background:rgba(255,255,255,0.12);"></span>
        </div>
        <div style="font-family:'Geist Mono',monospace; font-size:12px; letter-spacing:0.06em; color:var(--accent); margin-bottom:10px;">
          Phase 03
        </div>
        <h3 style="font-weight:600; font-size:21px; letter-spacing:-0.01em; margin:0 0 14px; color:#fafafa;">
          Execution
        </h3>
        <div style="display:flex; flex-direction:column; gap:9px;">
          <div style="font-size:14.5px; line-height:1.55; color:#9a9a9a;">Publish initial articles and videos</div>
          <div style="font-size:14.5px; line-height:1.55; color:#9a9a9a;">Fix priority docs gaps</div>
          <div style="font-size:14.5px; line-height:1.55; color:#9a9a9a;">Launch or seed the community space</div>
          <div style="font-size:14.5px; line-height:1.55; color:#9a9a9a;">Run a first AMA or office hours</div>
        </div>
      </div>
    </div>

    <!-- Outcome callout -->
    <div
      data-reveal
      class="outcome-box"
      style="margin-top:48px; border:1px solid color-mix(in srgb, var(--accent) 30%, transparent); border-radius:14px; padding:26px 30px; background:color-mix(in srgb, var(--accent) 9%, #0d0d0f); display:flex; align-items:center; gap:20px; flex-wrap:wrap;"
    >
      <span
        style="font-family:'Geist Mono',monospace; font-size:11.5px; letter-spacing:0.1em; text-transform:uppercase; color:var(--accent); white-space:nowrap;"
      >
        The outcome →
      </span>
      <span style="font-size:18px; line-height:1.5; color:#ededed; font-weight:500;">
        A live, working developer relations function: content flowing, a community with a home, and
        your developers actually being heard.
      </span>
    </div>
  </div>
</section>
