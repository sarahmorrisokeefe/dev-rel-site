<!-- Proof section — hidden until case studies are ready. Uncomment in index.astro to enable. -->
<section style="border-top:1px solid rgba(255,255,255,0.07); background:#0a0a0b;">
  <div style="max-width:1120px; margin:0 auto; padding:84px 32px;" class="section-pad">
    <div
      data-reveal
      style="display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap; margin-bottom:28px;"
    >
      <h2 style="font-weight:600; font-size:26px; letter-spacing:-0.02em; margin:0; color:#fafafa;">
        Proof, coming soon.
      </h2>
      <span style="font-size:14px; color:#8b8b8b; max-width:440px;">
        This practice is new, and I'm taking on founding clients now. Real case studies and outcomes
        will live here.
      </span>
    </div>

    <div class="proof-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:20px;">
      <div
        data-reveal
        style="border:1px dashed rgba(255,255,255,0.14); border-radius:14px; padding:28px; min-height:170px; display:flex; flex-direction:column; justify-content:space-between; background:repeating-linear-gradient(135deg,rgba(255,255,255,0.015),rgba(255,255,255,0.015) 10px,transparent 10px,transparent 20px);"
      >
        <span
          style="font-family:'Geist Mono',monospace; font-size:11.5px; letter-spacing:0.08em; text-transform:uppercase; color:#6f6f6f;"
          >Case study 01</span
        >
        <span style="font-size:15px; color:#7a7a7a;"
          >Your launch story could be the first one here.</span
        >
      </div>
      <div
        data-reveal
        style="border:1px dashed rgba(255,255,255,0.14); border-radius:14px; padding:28px; min-height:170px; display:flex; flex-direction:column; justify-content:space-between; background:repeating-linear-gradient(135deg,rgba(255,255,255,0.015),rgba(255,255,255,0.015) 10px,transparent 10px,transparent 20px);"
      >
        <span
          style="font-family:'Geist Mono',monospace; font-size:11.5px; letter-spacing:0.08em; text-transform:uppercase; color:#6f6f6f;"
          >Case study 02</span
        >
        <span style="font-size:15px; color:#7a7a7a;"
          >Activation &amp; retention results, swapped in as they land.</span
        >
      </div>
      <div
        data-reveal
        style="border:1px dashed rgba(255,255,255,0.14); border-radius:14px; padding:28px; min-height:170px; display:flex; flex-direction:column; justify-content:space-between; background:repeating-linear-gradient(135deg,rgba(255,255,255,0.015),rgba(255,255,255,0.015) 10px,transparent 10px,transparent 20px);"
      >
        <span
          style="font-family:'Geist Mono',monospace; font-size:11.5px; letter-spacing:0.08em; text-transform:uppercase; color:#6f6f6f;"
          >Testimonial</span
        >
        <span style="font-size:15px; color:#7a7a7a;"
          >A founding client's words will go right here.</span
        >
      </div>
    </div>
  </div>
</section>
